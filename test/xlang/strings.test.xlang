import test from test

fn TestStrLen() {
    expect(str_len("hello")).toEqual(5)
    expect(str_len("")).toEqual(0)
    return 0
}

fn TestStrEq() {
    expect(str_eq("abc", "abc")).toBeTrue()
    expect(str_eq("abc", "xyz")).toBeFalse()
    return 0
}

fn TestStrFind() {
    expect(str_find("hello world", "world")).toEqual(6)
    expect(str_find("hello", "z")).toEqual((0 - 1))
    return 0
}

fn TestStrSub() {
    expect(str_sub("hello world", 0, 5)).toEqual("hello")
    expect(str_sub("hello world", 6, 5)).toEqual("world")
    return 0
}

fn TestStrByte() {
    expect(str_byte("Hi", 0)).toEqual(72)
    expect(str_byte("Hi", 1)).toEqual(105)
    return 0
}
