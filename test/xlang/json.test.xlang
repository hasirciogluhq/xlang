import expect from test
import * as json from json

fn TestJsonParseInt() {
    local data = json.parse("{\"userId\": 7, \"id\": 42, \"completed\": 0}")
    expect(data.Int("userId")).toEqual(7)
    expect(data.Get("id").AsInt()).toEqual(42)
    return 0
}

fn TestJsonParseString() {
    local data = json.parse("{\"title\": \"hello world\"}")
    expect(data.String("title")).toEqual("hello world")
    expect(data.Get("title").AsString()).toEqual("hello world")
    return 0
}

fn TestJsonParseBool() {
    local data = json.parse("{\"done\": true, \"pending\": false}")
    expect(data.Bool("done")).toBeTrue()
    expect(data.Bool("pending")).toBeFalse()
    return 0
}

fn TestJsonHasKey() {
    local data = json.parse("{\"name\": \"xlang\"}")
    expect(data.Has("name")).toBeTrue()
    expect(data.Has("missing")).toBeFalse()
    return 0
}

fn TestJsonIsNull() {
    local data = json.parse("{\"value\": null}")
    expect(data.Null("value")).toBeTrue()
    expect(data.Null("value2")).toBeFalse()
    return 0
}
