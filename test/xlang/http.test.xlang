import http from http/router

fn TestExactRoute() {
    local r = router.NewRouter()
    r.Get("/ping", handler_ping)
    local h = r.Match("GET", "/ping")
    expect(h).not().toEqual(0)
    return 0
}

fn TestParamRoute() {
    local r = router.NewRouter()
    r.Get("/user/{id}", handler_user)
    local h = r.Match("GET", "/user/42")
    expect(h).not().toEqual(0)
    expect(router.URLParam("id")).toEqual("42")
    return 0
}

fn TestGroupRoute() {
    local r = router.NewRouter()
    local users = r.Group("/users")
    users.Get("/{id}", handler_user)
    local h = r.Match("GET", "/users/99")
    expect(h).not().toEqual(0)
    expect(router.URLParam("id")).toEqual("99")
    return 0
}

fn TestMountRoute() {
    local root = router.NewRouter()
    local api = router.NewRouter()
    api.Get("/status", handler_status)
    root.Mount("/api", api)
    local h = root.Match("GET", "/api/status")
    expect(h).not().toEqual(0)
    return 0
}

fn handler_ping() {
    return 0
}

fn handler_user() {
    return 0
}

fn handler_status() {
    return 0
}
