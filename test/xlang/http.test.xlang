import expect from test
import router from http/router

fn TestPingRoute() {
    local r = router.NewRouter()
    r.Get("/ping", handle_ping)
    local ctx = r.DispatchRequest("GET", "/ping")
    expect(ctx.status).toEqual(200)
    return 0
}

fn TestUserParamRoute() {
    local r = router.NewRouter()
    r.Get("/user/{id}", handle_user)
    local ctx = r.DispatchRequest("GET", "/user/42")
    expect(ctx.status).toEqual(200)
    return 0
}

fn TestGroupRoute() {
    local r = router.NewRouter()
    local api = r.Group("/api")
    api.Get("/ping", handle_ping)
    local ctx = r.DispatchRequest("GET", "/api/ping")
    expect(ctx.status).toEqual(200)
    return 0
}

fn TestContextBindRef() {
    local r = router.NewRouter()
    r.Use(inject_name)
    r.Get("/hello", handle_hello)
    local ctx = r.DispatchRequest("GET", "/hello")
    expect(ctx.status).toEqual(200)
    return 0
}

fn inject_name(ctx: Context) {
    ctx.Put("greeting", "hi")
    return 0
}

fn handle_ping(ctx: Context) {
    ctx.String(200, "pong")
    expect(1).toEqual(1)
    return 0
}

fn handle_user(ctx: Context) {
    expect(ctx.Param("id")).toEqual("42")
    ctx.String(200, "ok")
    return 0
}

fn handle_hello(ctx: Context) {
    expect(ctx.Get("greeting")).toEqual("hi")
    ctx.String(200, "ok")
    return 0
}
