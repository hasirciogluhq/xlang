import test from test
import router from http/router

fn TestPingRoute() {
    local r = router.NewRouter()
    r.Get("/ping", handle_ping)
    r.DispatchRequest("GET", "/ping")
    return 0
}

fn TestUserParamRoute() {
    local r = router.NewRouter()
    r.Get("/user/{id}", handle_user)
    r.DispatchRequest("GET", "/user/42")
    return 0
}

fn TestGroupRoute() {
    local r = router.NewRouter()
    local api = r.Group("/api")
    api.Get("/ping", handle_ping)
    r.DispatchRequest("GET", "/api/ping")
    return 0
}

fn handle_ping() {
    router.req.RespondText(200, "pong")
    expect(1).toEqual(1)
    return 0
}

fn handle_user() {
    expect(router.req.Param("id")).toEqual("42")
    router.req.RespondText(200, "ok")
    return 0
}
