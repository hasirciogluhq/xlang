import test from test
import router from http/router

fn TestPingRoute() {
    local r = router.NewRouter()
    r.Get("/ping", handle_ping)
    router.DispatchRequest(r, "GET", "/ping")
    return 0
}

fn TestUserParamRoute() {
    local r = router.NewRouter()
    r.Get("/user/{id}", handle_user)
    router.DispatchRequest(r, "GET", "/user/42")
    return 0
}

fn handle_ping() {
    router.RespondText(200, "pong")
    expect(1).toEqual(1)
    return 0
}

fn handle_user() {
    expect(router.RequestParam("id")).toEqual("42")
    router.RespondText(200, "ok")
    return 0
}
