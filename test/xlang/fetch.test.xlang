fn test_fetch_https_status() {
    local resp = fetch("https://jsonplaceholder.typicode.com/todos/1")
    expect_eq(resp.status, 200)
    expect_true(resp.ok)
    return 0
}

fn test_fetch_https_json_body() {
    local resp = fetch("https://jsonplaceholder.typicode.com/todos/1")
    expect_eq(json_get_int(resp.body, "userId"), 1)
    expect_eq(json_get_int(resp.body, "id"), 1)
    expect_str_eq(json_get_string(resp.body, "title"), "delectus aut autem")
    expect_false(json_get_bool(resp.body, "completed"))
    return 0
}

fn test_fetch_http_status() {
    local resp = fetch("http://example.com/")
    expect_eq(resp.status, 200)
    expect_true(resp.ok)
    return 0
}

fn main() {
    describe("fetch")
    it("https returns 200", test_fetch_https_status)
    it("https body parses as json", test_fetch_https_json_body)
    it("http returns 200", test_fetch_http_status)
    return test_summary()
}
