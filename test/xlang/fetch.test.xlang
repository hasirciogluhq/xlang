import * as test from test
import * as json from json

fn TestFetchHttpsStatus() {
    local resp = fetch("https://jsonplaceholder.typicode.com/todos/1")
    expect(resp.status).toEqual(200)
    expect(resp.ok).toBeTrue()
    return 0
}

fn TestFetchHttpsJsonBody() {
    local resp = fetch("https://jsonplaceholder.typicode.com/todos/1")
    local data = json.parse(resp.body)
    expect(data.Int("userId")).toEqual(1)
    expect(data.Int("id")).toEqual(1)
    expect(data.String("title")).toEqual("delectus aut autem")
    expect(data.Bool("completed")).toBeFalse()
    return 0
}

fn TestFetchHttpStatus() {
    local resp = fetch("http://example.com/")
    expect(resp.status).toEqual(200)
    expect(resp.ok).toBeTrue()
    return 0
}
