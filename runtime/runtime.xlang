declare syscall print_int(n)
declare syscall print_cstr(s)
declare syscall start_thread(entry, arg)

spawn_queue = 0

fn scheduler_loop(arg) {
    print_int(spawn_queue)
    return 0
}

export fn print_int(n) {
    return print_int(n)
}

export fn print_str(s: string) {
    return print_cstr(s)
}

export fn spawn(cmd) {
    spawn_queue = cmd
    return start_thread(scheduler_loop, cmd)
}
