// Paralel job scheduler — runtime spawn/wait_all (Go routine benzeri, saf xlang scheduler).
declare syscall sleep_ms(ms)
declare syscall random_range(min, max)
declare syscall print_done(job_id)

fn job_worker(job_id) {
    local delay_ms = random_range(100, 300)
    sleep_ms(delay_ms)
    print_done(job_id)
    return 0
}

fn main() {
    print("cpu: %d", cpu())
    spawn(job_worker, 1)
    spawn(job_worker, 2)
    spawn(job_worker, 3)
    spawn(job_worker, 4)
    wait_all()
    return 0
}
