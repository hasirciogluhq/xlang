{
  "Main function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Program entry point"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}) {",
      "\t$0",
      "}"
    ],
    "description": "Function definition"
  },
  "Typed function": {
    "prefix": "fnt",
    "body": [
      "fn ${1:name}(${2:arg}: ${3:int32}): ${4:int32} {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Function with typed params and return"
  },
  "Go test function": {
    "prefix": "testfn",
    "body": [
      "fn Test${1:Name}() {",
      "\texpect(${2:actual}).toEqual(${3:expected})",
      "\treturn 0",
      "}"
    ],
    "description": "Go-style Test* function (Vitest expect API)"
  },
  "Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:Name} {",
      "\t${2:Method}(${3:arg}: ${4:string}): ${5:int32}",
      "}"
    ],
    "description": "Interface definition"
  },
  "Go spawn": {
    "prefix": "go",
    "body": "go ${1:worker}(${2:args})",
    "description": "Spawn shorthand (go fn(args))"
  },
  "Local variable": {
    "prefix": "local",
    "body": "local ${1:name} = ${2:0}",
    "description": "Local variable"
  },
  "Typed local": {
    "prefix": "localt",
    "body": "local ${1:name}: ${2:int32} = ${3:0}",
    "description": "Typed local variable"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:int32}",
      "}"
    ],
    "description": "Struct definition"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If block"
  },
  "If else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If / else block"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "Import module": {
    "prefix": "import",
    "body": "import ${1:module}",
    "description": "Import and merge module"
  },
  "Import with alias": {
    "prefix": "importfrom",
    "body": "import ${1:expect} from ${2:test}",
    "description": "Selective symbol import (import expect from test)"
  },
  "Import as alias": {
    "prefix": "importas",
    "body": "import * as ${2:alias} from ${1:module}",
    "description": "Import module with namespace alias"
  },
  "From import": {
    "prefix": "from",
    "body": "from ${1:module} import ${2:name}",
    "description": "Selective import"
  },
  "Declare syscall": {
    "prefix": "syscall",
    "body": "declare syscall ${1:name}(${2:args})",
    "description": "OS syscall bridge declaration"
  },
  "Declare external": {
    "prefix": "external",
    "body": "declare external fn ${1:name}(${2:args})",
    "description": "External function declaration"
  },
  "New struct": {
    "prefix": "new",
    "body": "new ${1:Type} { ${2:field} = ${3:value} }",
    "description": "Struct initialization"
  },
  "Print": {
    "prefix": "print",
    "body": "print(\"${1:message}\")",
    "description": "Print call"
  },
  "Spawn": {
    "prefix": "spawn",
    "body": "spawn(${1:worker}(${2:args}))",
    "description": "Spawn a goroutine-like task"
  },
  "Fetch with JSON": {
    "prefix": "fetch",
    "body": [
      "import * as json from json",
      "",
      "local resp = fetch(\"${1:https://example.com}\")",
      "local data = json.parse(resp.body)",
      "local ${2:value} = data.${3|Int,String,Bool|}(\"${4:key}\")"
    ],
    "description": "HTTP fetch + json.parse"
  },
  "Expect equal": {
    "prefix": "expect",
    "body": "expect(${1:actual}).toEqual(${2:expected})",
    "description": "Vitest-style equality assertion"
  },
  "Expect string equal": {
    "prefix": "expectstr",
    "body": "expect(${1:actual}).toEqual(\"${2:expected}\")",
    "description": "String equality assertion"
  },
  "Expect true": {
    "prefix": "expecttrue",
    "body": "expect(${1:value}).toBeTrue()",
    "description": "Assert truthy value"
  },
  "Expect false": {
    "prefix": "expectfalse",
    "body": "expect(${1:value}).toBeFalse()",
    "description": "Assert falsy value"
  },
  "Expect throw": {
    "prefix": "expectthrow",
    "body": "expectFn(${1:handler}).toThrow()",
    "description": "Assert function panics"
  },
  "HTTP server": {
    "prefix": "httpserver",
    "body": [
      "import * as http from http",
      "",
      "fn handle_root(ctx: Context) {",
      "\tctx.String(200, \"ok\")",
      "\treturn 0",
      "}",
      "",
      "fn on_listen(info: ServerInfo) {",
      "\tprint(\"running at %s://%s:%d\", info.Protocol(), info.Hostname(), info.Port())",
      "\treturn 0",
      "}",
      "",
      "fn main() {",
      "\tlocal r = http.NewRouter()",
      "\tr.Get(\"/\", handle_root)",
      "\tr.ListenAndServe(\"127.0.0.1\", ${1:8080}, on_listen)",
      "\treturn 0",
      "}"
    ],
    "description": "HTTP server with router"
  },
  "HTTP route handler": {
    "prefix": "handler",
    "body": [
      "fn ${1:handle}(ctx: Context) {",
      "\tctx.String(200, \"${2:ok}\")",
      "\treturn 0",
      "}"
    ],
    "description": "HTTP handler with ctx.String/JSON/HTML"
  },
  "JSON parse": {
    "prefix": "jsonparse",
    "body": [
      "import * as json from json",
      "",
      "local data = json.parse(${1:body})",
      "local ${2:value} = data.${3|Int,String,Bool|}(\"${4:key}\")"
    ],
    "description": "json.parse + field accessor"
  },
  "File read/write": {
    "prefix": "filio",
    "body": [
      "import * as file from file",
      "",
      "file.Write(\"${1:path}\", \"${2:data}\")",
      "local body = file.ReadAll(\"${1:path}\")"
    ],
    "description": "file.Write + file.ReadAll"
  },
  "File stream": {
    "prefix": "filestream",
    "body": [
      "import * as file from file",
      "",
      "local f = file.OpenRead(\"${1:path}\")",
      "local body = file.Read(f)",
      "file.Close(f)"
    ],
    "description": "OpenRead + Read + Close"
  },
  "Test file header": {
    "prefix": "testfile",
    "body": [
      "import expect from test",
      "",
      "fn Test${1:Name}() {",
      "\texpect(${2:actual}).toEqual(${3:expected})",
      "\treturn 0",
      "}"
    ],
    "description": "Test file with expect import"
  }
}
