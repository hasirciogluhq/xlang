{
  "Main function": {
    "prefix": "main",
    "body": [
      "fn main() {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Program entry point"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:args}) {",
      "\t$0",
      "}"
    ],
    "description": "Function definition"
  },
  "Typed function": {
    "prefix": "fnt",
    "body": [
      "fn ${1:name}(${2:arg}: ${3:int32}): ${4:int32} {",
      "\t$0",
      "\treturn 0",
      "}"
    ],
    "description": "Function with typed params and return"
  },
  "Local variable": {
    "prefix": "local",
    "body": "local ${1:name} = ${2:0}",
    "description": "Local variable"
  },
  "Typed local": {
    "prefix": "localt",
    "body": "local ${1:name}: ${2:int32} = ${3:0}",
    "description": "Typed local variable"
  },
  "Struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:int32}",
      "}"
    ],
    "description": "Struct definition"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "If block"
  },
  "If else": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} {",
      "\t$2",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "If / else block"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "\t$0",
      "}"
    ],
    "description": "While loop"
  },
  "Import module": {
    "prefix": "import",
    "body": "import ${1:module}",
    "description": "Import and merge module"
  },
  "Import with alias": {
    "prefix": "importfrom",
    "body": "import ${1:http} from ${2:http}",
    "description": "import alias from module/path"
  },
  "Import as alias": {
    "prefix": "importas",
    "body": "import ${1:scheduler} as ${2:s}",
    "description": "Import module with alias"
  },
  "From import": {
    "prefix": "from",
    "body": "from ${1:module} import ${2:name}",
    "description": "Selective import"
  },
  "Declare syscall": {
    "prefix": "syscall",
    "body": "declare syscall ${1:name}(${2:args})",
    "description": "OS syscall bridge declaration"
  },
  "Declare external": {
    "prefix": "external",
    "body": "declare external fn ${1:name}(${2:args})",
    "description": "External function declaration"
  },
  "New struct": {
    "prefix": "new",
    "body": "new ${1:Type} { ${2:field} = ${3:value} }",
    "description": "Struct initialization"
  },
  "Print": {
    "prefix": "print",
    "body": "print(\"${1:message}\")",
    "description": "Print call"
  },
  "Spawn": {
    "prefix": "spawn",
    "body": "spawn(${1:worker}(${2:args}))",
    "description": "Spawn a goroutine-like task"
  },
  "Fetch": {
    "prefix": "fetch",
    "body": "fetch(\"${1:https://example.com}\")",
    "description": "HTTP GET request"
  },
  "Test file main": {
    "prefix": "testmain",
    "body": [
      "fn ${1:test_name}() {",
      "\t$0",
      "\treturn 0",
      "}",
      "",
      "fn main() {",
      "\tdescribe(\"${2:suite}\")",
      "\tit(\"${3:case}\", ${1:test_name})",
      "\treturn test_summary()",
      "}"
    ],
    "description": "Vitest-style test file scaffold"
  },
  "Describe suite": {
    "prefix": "describe",
    "body": "describe(\"${1:suite}\")",
    "description": "Test suite name"
  },
  "It case": {
    "prefix": "it",
    "body": "it(\"${1:name}\", ${2:test_fn})",
    "description": "Register test case"
  },
  "Expect equal": {
    "prefix": "expect",
    "body": "expect_eq(${1:actual}, ${2:expected})",
    "description": "Assert int32 equality"
  },
  "Expect string equal": {
    "prefix": "expectstr",
    "body": "expect_str_eq(${1:actual}, \"${2:expected}\")",
    "description": "Assert string equality"
  },
  "Expect true": {
    "prefix": "expecttrue",
    "body": "expect_true(${1:value})",
    "description": "Assert truthy value"
  },
  "Expect false": {
    "prefix": "expectfalse",
    "body": "expect_false(${1:value})",
    "description": "Assert falsy value"
  },
  "HTTP server": {
    "prefix": "httpserver",
    "body": [
      "import http from http",
      "",
      "fn handle_root() {",
      "\thttp.RespondText(200, \"ok\")",
      "\treturn 0",
      "}",
      "",
      "fn main() {",
      "\tlocal r = http.NewRouter()",
      "\tr.Get(\"/\", handle_root)",
      "\thttp.ListenAndServe(\"127.0.0.1\", ${1:8080}, r)",
      "\treturn 0",
      "}"
    ],
    "description": "HTTP server with router"
  },
  "HTTP route handler": {
    "prefix": "handler",
    "body": [
      "fn ${1:handle}() {",
      "\thttp.RespondText(200, \"${2:ok}\")",
      "\treturn 0",
      "}"
    ],
    "description": "HTTP handler with RespondText"
  },
  "JSON get field": {
    "prefix": "jsonget",
    "body": "json_get_string(${1:body}, \"${2:key}\")",
    "description": "Get JSON string field"
  }
}
