{
  "name": "xlang",
  "displayName": "xlang",
  "description": "Syntax highlighting, snippets, diagnostics, and formatting for the xlang programming language",
  "version": "1.0.0",
  "publisher": "xlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasirciogluhq/xlang.git"
  },
  "homepage": "https://github.com/hasirciogluhq/xlang#readme",
  "bugs": {
    "url": "https://github.com/hasirciogluhq/xlang/issues"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "xlang",
    "intellisense",
    "completion",
    "hover"
  ],
  "activationEvents": [
    "onLanguage:xlang"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "xlang",
        "aliases": [
          "xlang",
          "Xlang"
        ],
        "extensions": [
          ".xlang",
          ".test.xlang"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/xlang-light.svg",
          "dark": "./icons/xlang-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "xlang",
        "scopeName": "source.xlang",
        "path": "./syntaxes/xlang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "xlang",
        "path": "./snippets/xlang.json"
      }
    ],
    "configuration": {
      "title": "xlang",
      "properties": {
        "xlang.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the xlang compiler binary (build/xlank). Empty = auto-detect."
        },
        "xlang.xlankPath": {
          "type": "string",
          "default": "",
          "description": "Deprecated alias for xlang.compilerPath.",
          "deprecationMessage": "Use xlang.compilerPath instead."
        },
        "xlang.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run xlang parse on open/save and show errors."
        },
        "xlang.diagnosticsOnType": {
          "type": "boolean",
          "default": false,
          "description": "Re-run diagnostics while typing (debounced)."
        },
        "xlang.formatter.tabSize": {
          "type": "number",
          "default": 4,
          "minimum": 2,
          "maximum": 8,
          "description": "Indent size for the xlang formatter."
        },
        "xlang.testRoot": {
          "type": "string",
          "default": "test/xlang",
          "description": "Default directory for xlang test (relative to workspace root)."
        }
      }
    },
    "commands": [
      {
        "command": "xlang.runFile",
        "title": "xlang: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "xlang.buildFile",
        "title": "xlang: Build Current File"
      },
      {
        "command": "xlang.testFile",
        "title": "xlang: Test Current File",
        "icon": "$(beaker)"
      },
      {
        "command": "xlang.testSuite",
        "title": "xlang: Run Test Suite"
      },
      {
        "command": "xlang.formatDocument",
        "title": "xlang: Format Document"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "xlang.runFile",
          "when": "resourceLangId == xlang && resourceFilename !~ /\\.test\\.xlang$/",
          "group": "navigation"
        },
        {
          "command": "xlang.testFile",
          "when": "resourceLangId == xlang",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "bun run scripts/build.ts",
    "watch": "bun --watch run scripts/build.ts",
    "package": "bun run scripts/package.ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "bun-types": "^1.2.0"
  }
}
