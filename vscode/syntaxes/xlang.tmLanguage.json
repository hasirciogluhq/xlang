{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "xlang",
  "scopeName": "source.xlang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#declarations" },
    { "include": "#builtins" },
    { "include": "#method-calls" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xlang",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xlang",
              "match": "\\\\([\"\\\\nrt]|.)"
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.xlang",
          "match": "\\b(export\\s+)?(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.export.xlang" },
            "2": { "name": "keyword.other.fn.xlang" },
            "3": { "name": "entity.name.function.xlang" }
          }
        },
        {
          "name": "meta.test-function.xlang",
          "match": "\\bfn\\s+(Test[A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.test.xlang" }
          }
        },
        {
          "name": "meta.struct.xlang",
          "match": "\\b(export\\s+)?(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.export.xlang" },
            "2": { "name": "keyword.other.struct.xlang" },
            "3": { "name": "entity.name.type.struct.xlang" }
          }
        },
        {
          "name": "meta.interface.xlang",
          "match": "\\b(export\\s+)?(interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.export.xlang" },
            "2": { "name": "keyword.other.interface.xlang" },
            "3": { "name": "entity.name.type.interface.xlang" }
          }
        },
        {
          "name": "meta.import.alias-from.xlang",
          "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(from)\\s+([A-Za-z_][A-Za-z0-9_/]*)",
          "captures": {
            "1": { "name": "keyword.control.import.xlang" },
            "2": { "name": "variable.other.alias.xlang" },
            "3": { "name": "keyword.control.import.xlang" },
            "4": { "name": "entity.name.namespace.xlang" }
          }
        },
        {
          "name": "meta.import.module.xlang",
          "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_/]*)",
          "captures": {
            "1": { "name": "keyword.control.import.xlang" },
            "2": { "name": "entity.name.namespace.xlang" }
          }
        },
        {
          "name": "meta.import.from.xlang",
          "match": "\\b(from)\\s+([A-Za-z_][A-Za-z0-9_/]*)\\s+(import)",
          "captures": {
            "1": { "name": "keyword.control.import.xlang" },
            "2": { "name": "entity.name.namespace.xlang" },
            "3": { "name": "keyword.control.import.xlang" }
          }
        },
        {
          "name": "meta.declare.xlang",
          "match": "\\b(declare)\\s+(syscall|external)\\s+(fn)?\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.declare.xlang" },
            "2": { "name": "keyword.other.syscall.xlang" },
            "3": { "name": "keyword.other.fn.xlang" },
            "4": { "name": "entity.name.function.xlang" }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.runtime.xlang",
          "match": "\\b(print|fetch|spawn|wait_all|cpu|add_worker|parse)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.http.xlang",
          "match": "\\b(NewRouter|Get|Post|Put|Delete|Patch|Head|Options|Group|Mount|Use|Match|DispatchRequest|ListenAndServe|ServeOnce|Param|Method|Path|String|JSON|HTML|Bind|Ref|Protocol|Hostname|Port)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.sync.xlang",
          "match": "\\b(NewLock|NewRWLock|NewAtomicInt|NewAtomicBool|Lock|Unlock|SetTimeout|TryLock|IsHeld|ReadLock|ReadUnlock|WriteLock|WriteUnlock|SetWriteTimeout|WriteIsHeld|FetchAdd|CompareExchange)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.compiler.xlang",
          "match": "\\b(invoke0|invoke1|invoke|ref|str_len|str_eq|str_byte|str_find|str_sub|str_from_int|array_len|array_push|array_get|array_pop|array_pop_front)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.test.xlang",
          "match": "\\b(expect|expectFn|fail|panic|recover|test_run_one|test_finish_suite)\\b(?=\\s*\\()"
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "name": "meta.method-call.xlang",
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.member.xlang" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xlang",
          "match": "\\b(if|else|while|return|go)\\b"
        },
        {
          "name": "keyword.other.xlang",
          "match": "\\b(local|new|delete|import|from|as|export|external|syscall|declare|struct|interface|fn|array)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.xlang",
          "match": "\\b(void|int|int32|int64|bigint|float|float32|double|float64|bool|char|string)\\b"
        },
        {
          "name": "storage.type.pointer.xlang",
          "match": "\\*\\s*(void|int|int32|int64|bigint|float|float32|double|float64|bool|char|string|[A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "storage.type.array.xlang",
          "match": "\\barray\\s+[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.xlang",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.xlang",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.xlang",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cast.xlang",
          "match": "\\bas\\b"
        },
        {
          "name": "keyword.operator.xlang",
          "match": "(==|!=|<=|>=|&&|\\|\\||\\.\\.\\.)"
        },
        {
          "name": "keyword.operator.arithmetic.xlang",
          "match": "(\\+|\\-|\\*|/)"
        },
        {
          "name": "keyword.operator.assignment.xlang",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.xlang",
          "match": "(<|>)"
        }
      ]
    }
  }
}
